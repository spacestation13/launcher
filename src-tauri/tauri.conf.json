{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SS13 Launcher",
  "identifier": "com.ss13.launcher",
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["ss13"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0NjI0MjAxMjBGNDQzNzkKUldSNVEvUWdBVUppSkZIOUdldXFFa2RoNE1jeHp0NGVldTYvZmkwanp4MGRETWk5d2NEUXBCNW4K",
      "endpoints": [
        "https://github.com/cmss13-devs/launcher/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SS13 Launcher",
        "width": 800,
        "minWidth": 800,
        "height": 540,
        "minHeight": 540,
        "decorations": false,
        "resizable": true,
        "center": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "resources": [
      "icons/ss13/icon.png"
    ],
    "publisher": "SS13",
    "copyright": "Copyright 2026 SS13",
    "category": "Game",
    "shortDescription": "Game launcher for SS13 servers",
    "longDescription": "Launcher for SS13 servers. Manages BYOND game client installations.",
    "windows": {
      "allowDowngrades": true,
      "nsis": {
        "installMode": "both",
        "installerIcon": "icons/ss13/icon.ico"
      },
      "wix": null,
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "webview2-runtime"
      }
    },
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/ss13/32x32.png",
      "icons/ss13/128x128.png",
      "icons/ss13/128x128@2x.png",
      "icons/ss13/icon.icns",
      "icons/ss13/icon.ico"
    ]
  }
}
